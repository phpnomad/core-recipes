        },
        "taskId": {
            "type": "string",
            "description": "Unique task identifier (e.g. email.send)"
        }
    },
    "requires": [],
    "files": [
        {
            "path": "lib/Tasks/{{name}}.php",
            "template": "task"
        }
    ],
    "registrations": []
}
